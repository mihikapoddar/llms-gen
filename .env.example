# Copy to .env and adjust
LLMS_GEN_DATABASE_URL=sqlite+aiosqlite:///./llms_gen.db
LLMS_GEN_CRAWL_USER_AGENT=llms-gen/0.1 (+https://github.com/yourorg/llms-gen)
LLMS_GEN_MAX_PAGES_PER_JOB=60
LLMS_GEN_FETCH_TIMEOUT_S=20.0
LLMS_GEN_MAX_RESPONSE_BYTES=2097152
LLMS_GEN_MONITOR_ENABLED=true
LLMS_GEN_MONITOR_POLL_INTERVAL_S=300
# Optional: full public origin so webhook JSON includes absolute artifact URLs (e.g. https://your-app.fly.dev)
LLMS_GEN_PUBLIC_BASE_URL=
